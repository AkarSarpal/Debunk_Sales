# Required
LEMLIST_API_KEY=your_lemlist_api_key_here
LEMLIST_CAMPAIGN_ID=cam_D4cKonCgWRYoNiEDR

# Free key — cuts NVD runtime from ~7min to ~40sec
# Request at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Censys API (deprecated — free programmatic access removed June 2026)
# Personal Access Tokens do not grant search API access on free accounts.
# Pipeline runs in inferred mode automatically when these are absent.
CENSYS_API_ID=
CENSYS_API_SECRET=

# VirusTotal free tier (500 req/day) — tech stack hints from passive DNS/HTTP headers
# Sign up at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# Optional — enables breach lookup per domain
# Purchase at: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# Optional — for Claude synthesis in future iterations
ANTHROPIC_API_KEY=
